# ─────────────────────────────────────────────────────────────────────────────
# secrets.toml.example — ZEL-EYE-OI configuration template
#
# Copy this file to secrets.toml and fill in your real values.
#   cp secrets.toml.example secrets.toml
#
# secrets.toml is git-ignored and will NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase credentials
SUPABASE_URL          = "https://<your-project>.supabase.co"
SUPABASE_ANON_KEY     = "<your-anon-key>"
SUPABASE_SERVICE_ROLE_KEY = "<your-service-role-key>"

# AWS / S3 — DuckDB download (read credentials)
AWS_ACCESS_KEY_ID     = "<your-aws-access-key-id>"
AWS_SECRET_ACCESS_KEY = "<your-aws-secret-access-key>"
AWS_REGION            = "eu-north-1"
S3_BUCKET             = "zelestra-duckdb"
S3_KEY                = "master.duckdb"

# AWS — separate upload credentials (optional; used only by master_run.py)
AWS_ACCESS_KEY_ID_UPLOAD     = ""
AWS_SECRET_ACCESS_KEY_UPLOAD = ""

# SSL — set "false" only on corporate proxies with self-signed certificates
AWS_SSL_VERIFY = "true"

# JWT signing secret — generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY = "<generate-a-64-char-hex-string>"
